page {
  background: #f6f7fb;
  color: #1f2937;
  font-size: 28rpx;
}

.container {
  padding: 32rpx;
}

.card {
  background: #fff;
  border-radius: 24rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 20rpx;
}

.subtitle {
  font-size: 26rpx;
  color: #6b7280;
}

.btn-row {
  display: flex;
  gap: 20rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.primary-btn {
  background: #2563eb;
  color: #fff;
}

.danger-btn {
  background: #dc2626;
  color: #fff;
}

.tag {
  display: inline-block;
  padding: 8rpx 18rpx;
  margin-right: 12rpx;
  margin-bottom: 12rpx;
  border-radius: 999rpx;
  background: #e0ecff;
  color: #1d4ed8;
  font-size: 22rpx;
}

.field-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.input, .textarea {
  width: 100%;
  background: #f8fafc;
  border: 1rpx solid #dbe3ef;
  border-radius: 16rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.textarea {
  min-height: 180rpx;
}

.empty {
  text-align: center;
  color: #9ca3af;
  padding: 48rpx 0;
}
