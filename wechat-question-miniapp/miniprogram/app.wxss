page {
  background: linear-gradient(180deg, #f3f7ff 0%, #f8fafc 45%, #eef4ff 100%);
  color: #1f2937;
  font-size: 28rpx;
}

.container {
  padding: 28rpx;
}

.page-shell {
  position: relative;
}

.page-shell::before {
  content: '';
  position: fixed;
  top: -120rpx;
  right: -80rpx;
  width: 320rpx;
  height: 320rpx;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(96, 165, 250, 0.28) 0%, rgba(96, 165, 250, 0) 70%);
  pointer-events: none;
}

.card,
.result-card,
.hero-card,
.metric-card,
.glass-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(219, 231, 245, 0.75);
  box-sizing: border-box;
}

.hero-card {
  background: linear-gradient(135deg, #123fa5 0%, #2563eb 58%, #60a5fa 100%);
  color: #fff;
  overflow: hidden;
  position: relative;
}

.hero-card::after {
  content: '';
  position: absolute;
  right: -40rpx;
  top: -20rpx;
  width: 220rpx;
  height: 220rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.12);
}

.glass-card {
  background: linear-gradient(180deg, rgba(255, 255, 255, 0.92) 0%, rgba(245, 249, 255, 0.95) 100%);
}

.section-block + .section-block {
  margin-top: 4rpx;
}

.eyebrow {
  display: inline-flex;
  align-items: center;
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  margin-bottom: 18rpx;
}

.hero-title,
.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
  position: relative;
  z-index: 1;
}

.hero-subtitle,
.subtitle,
.feature-desc,
.content-text,
.body-text {
  font-size: 26rpx;
  line-height: 1.7;
  color: #5b6473;
}

.hero-subtitle {
  color: rgba(255, 255, 255, 0.92);
  position: relative;
  z-index: 1;
}

.no-gap,
.title-small {
  margin-bottom: 0;
}

.title-small {
  font-size: 32rpx;
}

.btn-row {
  display: flex;
  gap: 18rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
}

.btn-row-tight {
  margin-top: 28rpx;
}

button {
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 0 28rpx;
  border: none;
}

button::after {
  border: none;
}

.primary-btn {
  background: linear-gradient(135deg, #2563eb 0%, #1d4ed8 100%);
  color: #fff;
}

.secondary-btn {
  background: #eef4ff;
  color: #1d4ed8;
}

.ghost-btn {
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
  border: 1rpx solid rgba(255, 255, 255, 0.22);
}

.danger-btn {
  background: #dc2626;
  color: #fff;
}

.stats-grid,
.info-grid,
.grid-2,
.panel-grid,
.feature-grid,
.timeline-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.stats-grid > view,
.info-grid > view,
.grid-2 > view,
.panel-grid > view,
.feature-grid > view,
.timeline-grid > view {
  width: calc(50% - 9rpx);
  box-sizing: border-box;
}

.metric-card {
  margin-bottom: 0;
}

.metric-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #1d4ed8;
}

.metric-label,
.info-label,
.footer-note,
.toolbar-note,
.helper-text,
.muted-text {
  font-size: 24rpx;
  color: #6b7280;
}

.section-header,
.search-toolbar,
.result-footer,
.list-title-row,
.meta-row,
.search-bar,
.inline-between {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.section-title,
.feature-title,
.panel-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.section-caption {
  font-size: 24rpx;
  color: #64748b;
  margin-top: 8rpx;
}

.feature-item + .feature-item {
  margin-top: 18rpx;
}

.feature-grid .feature-item,
.panel-grid .panel-card,
.timeline-grid .timeline-card,
.kpi-grid .kpi-card {
  width: calc(50% - 9rpx);
}

.panel-card,
.timeline-card,
.kpi-card,
.info-card {
  background: linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
  border: 1rpx solid #dbe7fb;
  border-radius: 24rpx;
  padding: 24rpx;
  box-sizing: border-box;
}

.panel-accent {
  background: linear-gradient(135deg, #eff6ff 0%, #dbeafe 100%);
}

.kpi-value {
  font-size: 38rpx;
  font-weight: 700;
  color: #1e40af;
}

.kpi-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #64748b;
}

.kpi-desc,
.panel-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #475569;
}

.status-dot {
  display: inline-block;
  width: 14rpx;
  height: 14rpx;
  border-radius: 50%;
  background: #22c55e;
  margin-right: 10rpx;
}

.status-dot-warning {
  background: #f59e0b;
}

.status-dot-danger {
  background: #ef4444;
}

.tag-row,
.filter-row,
.badge-row,
.pill-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.inline-tags {
  flex: 1;
}

.tag,
.meta-pill,
.filter-chip,
.picker-chip,
.soft-badge {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #e8f0ff;
  color: #1d4ed8;
  font-size: 22rpx;
}

.soft-badge {
  background: #eff6ff;
}

.meta-pill-light,
.picker-chip,
.filter-chip,
.soft-badge-neutral {
  background: #f3f4f6;
  color: #4b5563;
}

.filter-chip-active {
  background: #1d4ed8;
  color: #fff;
}

.picker-block {
  display: flex;
  width: 100%;
  justify-content: flex-start;
  border-radius: 16rpx;
  padding: 22rpx;
}

.tag-clickable,
.link-text {
  cursor: pointer;
}

.link-text,
.error-text,
.highlight-text,
.link-btn {
  color: #2563eb;
}

.highlight-text {
  background: #fff3bf;
  color: #92400e;
  border-radius: 8rpx;
}

.input,
.textarea {
  width: 100%;
  background: #f8fafc;
  border: 1rpx solid #dbe3ef;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.search-input {
  flex: 1;
}

.search-btn {
  min-width: 156rpx;
}

.textarea {
  min-height: 180rpx;
}

.textarea-xl {
  min-height: 400rpx;
}

.field-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.field-gap,
.field-block {
  margin-top: 20rpx;
}

.option-item,
.info-value {
  font-size: 28rpx;
  line-height: 1.7;
  color: #111827;
}

.answer-box {
  padding: 20rpx;
  border-radius: 18rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-weight: 600;
}

.result-card {
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.6;
  color: #111827;
}

.result-desc,
.clamp-2 {
  margin-top: 12rpx;
  color: #4b5563;
  line-height: 1.7;
}

.filter-scroll {
  white-space: nowrap;
  margin-top: 18rpx;
}

.admin-stats {
  margin-top: 22rpx;
}

.large-gap {
  margin-top: 18rpx;
}

.small-gap {
  margin-top: 10rpx;
}

.tiny-gap {
  margin-top: 6rpx;
}

.empty {
  text-align: center;
  color: #9ca3af;
  padding: 56rpx 28rpx;
}

.page-intro {
  margin-bottom: 24rpx;
}

.page-headline {
  font-size: 42rpx;
  font-weight: 700;
  line-height: 1.4;
  color: #0f172a;
}

.page-subheadline {
  margin-top: 12rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #64748b;
}

.quick-nav {
  display: flex;
  gap: 14rpx;
  margin-top: 22rpx;
  flex-wrap: wrap;
}

.quick-nav-item {
  padding: 12rpx 20rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.08);
  color: #1d4ed8;
  font-size: 22rpx;
}

.timeline-card {
  position: relative;
}

.timeline-step {
  font-size: 22rpx;
  font-weight: 700;
  color: #2563eb;
  margin-bottom: 10rpx;
}

.timeline-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.timeline-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: #475569;
}

.divider {
  height: 1rpx;
  background: #edf2f7;
  margin: 22rpx 0;
}
