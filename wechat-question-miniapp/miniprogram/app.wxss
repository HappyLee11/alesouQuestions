page {
  background: linear-gradient(180deg, #f3f7ff 0%, #f8fafc 100%);
  color: #1f2937;
  font-size: 28rpx;
}

.container {
  padding: 28rpx;
}

.card,
.result-card,
.hero-card,
.metric-card {
  background: rgba(255, 255, 255, 0.96);
  border-radius: 28rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 16rpx 40rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid rgba(219, 231, 245, 0.7);
}

.hero-card {
  background: linear-gradient(135deg, #1d4ed8 0%, #2563eb 55%, #60a5fa 100%);
  color: #fff;
}

.eyebrow {
  display: inline-block;
  font-size: 22rpx;
  padding: 8rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.18);
  margin-bottom: 18rpx;
}

.hero-title,
.title {
  font-size: 36rpx;
  font-weight: 700;
  margin-bottom: 16rpx;
}

.hero-subtitle,
.subtitle,
.feature-desc,
.content-text {
  font-size: 26rpx;
  line-height: 1.7;
  color: #5b6473;
}

.hero-subtitle {
  color: rgba(255, 255, 255, 0.9);
}

.no-gap,
.title-small {
  margin-bottom: 0;
}

.title-small {
  font-size: 32rpx;
}

.btn-row {
  display: flex;
  gap: 18rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
}

.btn-row-tight {
  margin-top: 28rpx;
}

button {
  border-radius: 999rpx;
  font-size: 28rpx;
  padding: 0 28rpx;
}

.primary-btn {
  background: #2563eb;
  color: #fff;
}

.secondary-btn {
  background: #eef4ff;
  color: #1d4ed8;
}

.danger-btn {
  background: #dc2626;
  color: #fff;
}

.stats-grid,
.info-grid,
.grid-2 {
  display: flex;
  flex-wrap: wrap;
  gap: 18rpx;
}

.stats-grid > view,
.info-grid > view,
.grid-2 > view {
  width: calc(50% - 9rpx);
  box-sizing: border-box;
}

.metric-card {
  margin-bottom: 0;
}

.metric-value {
  font-size: 44rpx;
  font-weight: 700;
  color: #1d4ed8;
}

.metric-label,
.info-label,
.footer-note,
.toolbar-note {
  font-size: 24rpx;
  color: #6b7280;
}

.section-header,
.search-toolbar,
.result-footer,
.list-title-row,
.meta-row,
.search-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 16rpx;
}

.section-title,
.feature-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #111827;
}

.feature-item + .feature-item {
  margin-top: 18rpx;
}

.tag-row,
.filter-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.inline-tags {
  flex: 1;
}

.tag,
.meta-pill,
.filter-chip,
.picker-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: #e8f0ff;
  color: #1d4ed8;
  font-size: 22rpx;
}

.meta-pill-light,
.picker-chip,
.filter-chip {
  background: #f3f4f6;
  color: #4b5563;
}

.filter-chip-active {
  background: #1d4ed8;
  color: #fff;
}

.picker-block {
  display: flex;
  width: 100%;
  justify-content: flex-start;
  border-radius: 16rpx;
  padding: 22rpx;
}

.tag-clickable,
.link-text {
  cursor: pointer;
}

.link-text,
.error-text,
.highlight-text {
  color: #2563eb;
}

.highlight-text {
  background: #fff3bf;
  color: #92400e;
  border-radius: 8rpx;
}

.input,
.textarea {
  width: 100%;
  background: #f8fafc;
  border: 1rpx solid #dbe3ef;
  border-radius: 18rpx;
  padding: 20rpx;
  box-sizing: border-box;
}

.search-input {
  flex: 1;
}

.search-btn {
  min-width: 156rpx;
}

.textarea {
  min-height: 180rpx;
}

.textarea-xl {
  min-height: 400rpx;
}

.field-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-bottom: 10rpx;
}

.field-gap,
.field-block {
  margin-top: 20rpx;
}

.option-item,
.info-value {
  font-size: 28rpx;
  line-height: 1.7;
  color: #111827;
}

.answer-box {
  padding: 20rpx;
  border-radius: 18rpx;
  background: #eff6ff;
  color: #1d4ed8;
  font-weight: 600;
}

.result-card {
  margin-bottom: 20rpx;
}

.result-title {
  font-size: 32rpx;
  font-weight: 700;
  line-height: 1.6;
  color: #111827;
}

.result-desc,
.clamp-2 {
  margin-top: 12rpx;
  color: #4b5563;
  line-height: 1.7;
}

.filter-scroll {
  white-space: nowrap;
  margin-top: 18rpx;
}

.admin-stats {
  margin-top: 22rpx;
}

.large-gap {
  margin-top: 18rpx;
}

.small-gap {
  margin-top: 10rpx;
}

.empty {
  text-align: center;
  color: #9ca3af;
  padding: 56rpx 28rpx;
}
