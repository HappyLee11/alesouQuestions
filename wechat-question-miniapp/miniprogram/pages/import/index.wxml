<view class="container">
  <view class="card">
    <view class="title">批量导入题目</view>
    <view class="subtitle">支持多文档模板合并后的 JSON 数组演示，重点展示字段别名识别、导入前预检、去重与批量错误反馈。</view>
    <view wx:if="{{parseError}}" class="error-text">{{parseError}}</view>
    <textarea class="textarea textarea-xl" value="{{text}}" bindinput="onInput"></textarea>
    <view class="btn-row">
      <button class="secondary-btn" loading="{{loading}}" bindtap="previewOnCloud">先做预检</button>
      <button class="primary-btn" loading="{{loading}}" bindtap="handleImport">执行导入</button>
    </view>
  </view>

  <view class="card" wx:if="{{preview}}">
    <view class="section-title">本地预览</view>
    <view class="feature-desc">条数：{{preview.total}}</view>
    <view class="feature-desc">检测到的列：{{preview.columns.join('、')}}</view>
    <view class="field-block">
      <view class="field-label">样例记录</view>
      <view class="feature-desc" wx:for="{{preview.sample}}" wx:key="index">#{{item.index + 1}} {{item.title}} ｜ {{item.keys}}</view>
    </view>
  </view>

  <view class="card">
    <view class="section-title">当前支持的字段映射示例</view>
    <view class="feature-desc">title ← title / 题目 / questionTitle</view>
    <view class="feature-desc">content ← content / 题干 / description</view>
    <view class="feature-desc">answer ← answer / 答案 / result</view>
    <view class="feature-desc">analysis ← analysis / 解析 / explanation</view>
    <view class="feature-desc">tags ← tags / 标签 / tagList</view>
    <view class="feature-desc">type ← type / 题型 / questionType</view>
    <view class="feature-desc">titleVariants ← titleVariants / 标题变体 / 别名 / aliases</view>
  </view>

  <view class="card" wx:if="{{importResult}}">
    <view class="section-title">云端预检 / 导入结果</view>
    <view class="feature-desc">状态：{{importResult.success ? '成功' : '失败'}}</view>
    <view class="feature-desc" wx:if="{{importResult.data}}">有效：{{importResult.data.valid !== undefined ? importResult.data.valid : '-'}} ｜ 无效：{{importResult.data.invalid !== undefined ? importResult.data.invalid : importResult.data.failed || 0}}</view>
    <view class="feature-desc" wx:if="{{importResult.data}}">新增：{{importResult.data.inserted || 0}} ｜ 更新：{{importResult.data.updated || 0}} ｜ 去重命中：{{importResult.data.deduplicated || 0}}</view>
    <view class="field-block" wx:if="{{importResult.data && importResult.data.preview && importResult.data.preview.length}}">
      <view class="field-label">预检样例</view>
      <view class="feature-desc" wx:for="{{importResult.data.preview}}" wx:key="index">#{{item.index + 1}} {{item.title || '未命名'}} ｜ {{item.subject || '未分类'}} ｜ {{item.type}} ｜ {{item.difficulty}} {{item.errors.length ? '｜错误：' + item.errors.join(', ') : ''}}</view>
    </view>
    <view class="field-block" wx:if="{{importResult.data && importResult.data.errors && importResult.data.errors.length}}">
      <view class="field-label">错误列表</view>
      <view class="error-text" wx:for="{{importResult.data.errors}}" wx:key="index">#{{item.index + 1}} {{item.title || '未命名'}}：{{item.errors.join(', ')}}</view>
    </view>
  </view>
</view>
