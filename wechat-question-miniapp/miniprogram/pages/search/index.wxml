<view class="container page-shell page-search">
  <view class="hero-card search-hero">
    <view class="eyebrow">搜索题目</view>
    <view class="hero-title">找答案，直接搜</view>
    <view class="hero-subtitle">先输入关键词，再按学科、难度、题型和标签逐步缩小范围，整个流程更适合手机单手浏览。</view>

    <view class="search-bar search-hero-bar">
      <input class="input search-input search-hero-input" placeholder="输入题目关键词或题干片段" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="handleSearch" />
      <button class="primary-btn search-btn" loading="{{loading}}" bindtap="handleSearch">搜索</button>
    </view>

    <view class="tag-row small-gap" wx:if="{{quickTerms.length}}">
      <text class="hero-chip" wx:for="{{quickTerms}}" wx:key="*this" data-term="{{item}}" bindtap="onTapTerm">{{item}}</text>
    </view>
  </view>

  <view class="glass-card search-summary-card">
    <view class="section-header search-section-header">
      <view>
        <view class="section-title">搜索概览</view>
        <view class="section-caption">共 {{resultMeta.total}} 条结果 · 第 {{resultMeta.page}} / {{resultMeta.totalPages}} 页</view>
      </view>
      <picker mode="selector" range="{{sortOptions}}" range-key="label" value="{{sortIndex}}" bindchange="onChangeSort">
        <view class="picker-chip">{{sortOptions[sortIndex].label}}</view>
      </picker>
    </view>

    <view class="meta-row wrap-row small-gap source-meta-row">
      <text class="meta-pill meta-pill-light">数据来源：{{resultMeta.sourceLabel}}</text>
      <text class="meta-pill meta-pill-light" wx:if="{{activeFilterText !== '未启用筛选'}}">当前筛选：{{activeFilterText}}</text>
    </view>
    <view class="toolbar-note small-gap toolbar-note-warn" wx:if="{{sourceNotice}}">{{sourceNotice}}</view>
    <view class="tag-row small-gap" wx:if="{{topSuggestions.length}}">
      <text class="tag tag-clickable" wx:for="{{topSuggestions}}" wx:key="*this" data-term="{{item}}" bindtap="onTapTerm">{{item}}</text>
    </view>
  </view>

  <view class="card search-discovery-card" wx:if="{{history.length || hotTerms.length}}">
    <view class="section-header search-section-header">
      <view>
        <view class="section-title">继续搜索</view>
        <view class="section-caption">用最近记录和热门词快速回到结果页。</view>
      </view>
      <text class="link-text" wx:if="{{history.length}}" bindtap="clearHistory">清空历史</text>
    </view>

    <view class="search-discovery-block" wx:if="{{history.length}}">
      <view class="filter-label search-block-title">最近搜索</view>
      <view class="tag-row small-gap">
        <text class="tag tag-clickable" wx:for="{{history}}" wx:key="*this" data-term="{{item}}" bindtap="onTapTerm">{{item}}</text>
      </view>
    </view>

    <view class="search-discovery-block" wx:if="{{hotTerms.length}}">
      <view class="filter-label search-block-title">热门关键词</view>
      <view class="tag-row small-gap">
        <text class="tag tag-clickable" wx:for="{{hotTerms}}" wx:key="*this" data-term="{{item}}" bindtap="onTapTerm">{{item}}</text>
      </view>
    </view>
  </view>

  <view class="card search-filter-card" wx:if="{{displayList.length}}">
    <view class="section-header search-section-header">
      <view>
        <view class="section-title">筛选结果</view>
        <view class="section-caption">把条件拆成分组，避免一整页标签挤在一起。</view>
      </view>
    </view>

    <view class="filter-group">
      <view class="filter-label search-block-title">学科</view>
      <view class="tag-row small-gap">
        <text class="filter-chip {{currentFilters.subject === item.value ? 'filter-chip-active' : ''}}" wx:for="{{filterOptions.subject}}" wx:key="label" data-field="subject" data-value="{{item.value}}" bindtap="onTapFilter">{{item.label}}</text>
      </view>
    </view>

    <view class="filter-group">
      <view class="filter-label search-block-title">难度</view>
      <view class="tag-row small-gap">
        <text class="filter-chip {{currentFilters.difficulty === item.value ? 'filter-chip-active' : ''}}" wx:for="{{filterOptions.difficulty}}" wx:key="label" data-field="difficulty" data-value="{{item.value}}" bindtap="onTapFilter">{{item.label}}</text>
      </view>
    </view>

    <view class="filter-group">
      <view class="filter-label search-block-title">题型</view>
      <view class="tag-row small-gap">
        <text class="filter-chip {{currentFilters.type === item.value ? 'filter-chip-active' : ''}}" wx:for="{{filterOptions.type}}" wx:key="label" data-field="type" data-value="{{item.value}}" bindtap="onTapFilter">{{item.value ? (item.value === 'single' ? '单选题' : item.value === 'multiple' ? '多选题' : '问答题') : item.label}}</text>
      </view>
    </view>

    <view class="filter-group">
      <view class="filter-label search-block-title">标签</view>
      <view class="tag-row small-gap">
        <text class="filter-chip {{currentFilters.tag === item.value ? 'filter-chip-active' : ''}}" wx:for="{{filterOptions.tag}}" wx:key="label" data-field="tag" data-value="{{item.value}}" bindtap="onTapFilter">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view wx:if="{{displayList.length}}" class="search-results-list">
    <view class="result-card search-result-card" wx:for="{{displayList}}" wx:key="_id">
      <view data-id="{{item._id}}" bindtap="goDetail">
        <view class="result-title">
          <text wx:for="{{item.titleSegments}}" wx:for-item="segment" wx:key="index" class="{{segment.match ? 'highlight-text' : ''}}">{{segment.text}}</text>
        </view>
        <view class="result-desc clamp-2">
          <text wx:for="{{item.contentSegments}}" wx:for-item="segment" wx:key="index" class="{{segment.match ? 'highlight-text' : ''}}">{{segment.text}}</text>
        </view>
      </view>
      <view class="meta-row wrap-row result-meta-row">
        <text class="meta-pill">{{item.subject || '未分类'}}</text>
        <text class="meta-pill meta-pill-light">{{item.category || '通用'}}</text>
        <text class="meta-pill meta-pill-light">{{item.difficultyText}}</text>
        <text class="meta-pill meta-pill-light">{{item.typeText}}</text>
      </view>
      <view class="answer-preview">答案摘要：{{expandMap[item._id] ? item.analysisPreview : item.answerPreview}}</view>
      <text class="link-text small-gap inline-link" data-id="{{item._id}}" bindtap="toggleAnswer">{{expandMap[item._id] ? '收起解析' : '展开解析'}}</text>
      <view class="result-footer">
        <view class="tag-row inline-tags">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
        </view>
        <text class="footer-note">更新于 {{item.updatedAtText}}</text>
      </view>
    </view>
  </view>

  <view class="card search-pager-card" wx:if="{{displayList.length && resultMeta.totalPages > 1}}">
    <view class="section-header search-section-header">
      <view>
        <view class="section-title">分页浏览</view>
        <view class="section-caption">当前第 {{resultMeta.page}} / {{resultMeta.totalPages}} 页</view>
      </view>
    </view>
    <view class="btn-row pager-btn-row">
      <button class="pager-btn" bindtap="goPrevPage" disabled="{{!resultMeta.hasPrev}}">上一页</button>
      <button class="secondary-btn pager-btn" bindtap="goNextPage" disabled="{{!resultMeta.hasMore}}">下一页</button>
    </view>
  </view>

  <view wx:if="{{!displayList.length}}" class="card empty empty-card-strong search-empty-card">
    <view class="empty-badge">暂无匹配结果</view>
    <view class="title-small empty-title">{{emptyState.title}}</view>
    <view class="subtitle small-gap empty-desc">{{emptyState.description}}</view>
    <view class="empty-tip-list" wx:if="{{emptyState.tips && emptyState.tips.length}}">
      <view class="empty-tip-item" wx:for="{{emptyState.tips}}" wx:key="index">• {{item}}</view>
    </view>
    <view class="empty-suggestion-title" wx:if="{{emptyState.suggestions.length}}">你也可以试试这些词</view>
    <view class="tag-row small-gap" wx:if="{{emptyState.suggestions.length}}">
      <text class="tag tag-clickable" wx:for="{{emptyState.suggestions}}" wx:key="*this" data-term="{{item}}" bindtap="onTapTerm">{{item}}</text>
    </view>
  </view>
</view>
