/* page styles inherit app.wxss */

.search-hero-bar {
  margin-top: 28rpx;
  align-items: center;
}

.search-hero-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.96);
  color: #111827;
}

.hero-chip {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: #fff;
  font-size: 22rpx;
}

.filter-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 18rpx;
  margin-bottom: 10rpx;
}

.result-meta-row {
  margin-top: 18rpx;
}

.answer-preview {
  margin-top: 14rpx;
  font-size: 26rpx;
  line-height: 1.7;
  color: #374151;
}

.source-meta-row {
  margin-top: 16rpx;
}

.inline-link {
  display: inline-block;
}
