/* search page */
.search-toolbar-wrap {
  flex-wrap: wrap;
  align-items: flex-start;
}

.wrap-row {
  flex-wrap: wrap;
}

.filter-label {
  font-size: 24rpx;
  color: #6b7280;
  margin-top: 16rpx;
  margin-bottom: 8rpx;
}

.compact-result {
  padding: 0;
  margin-bottom: 0;
  box-shadow: none;
  border: 0;
}

.compact-result + .compact-result {
  margin-top: 16rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid #edf2f7;
}

.answer-preview {
  margin-top: 14rpx;
  font-size: 24rpx;
  line-height: 1.7;
  color: #475569;
}

.inline-link {
  display: inline-block;
}
