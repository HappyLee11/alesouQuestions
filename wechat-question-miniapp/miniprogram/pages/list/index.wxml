<view class="container page-shell">
  <view class="hero-card">
    <view class="eyebrow">Question Inventory</view>
    <view class="hero-title">题目列表与状态管理</view>
    <view class="hero-subtitle">在这里集中展示题库记录、审核态、生命周期、导入批次和版本信息，方便讲后台内容治理。</view>
    <view class="meta-row wrap-row large-gap" wx:if="{{isAdmin && admin}}">
      <text class="meta-pill">角色：{{admin.roleLabel || admin.role}}</text>
      <text class="meta-pill meta-pill-light">权限：{{permissions.length}} 项</text>
    </view>
  </view>

  <view wx:if="{{checking}}" class="card empty">正在校验权限...</view>
  <view wx:elif="{{!isAdmin}}" class="card empty">当前账号不是管理员，无法查看管理列表。</view>
  <block wx:else>
    <view class="panel-grid">
      <view class="panel-card" wx:for="{{summaryCards}}" wx:key="label">
        <view class="panel-title">{{item.label}}</view>
        <view class="kpi-value">{{item.value}}</view>
        <view class="panel-desc">{{item.desc}}</view>
      </view>
    </view>

    <view class="glass-card">
      <view class="search-bar">
        <input class="input search-input" placeholder="按标题 / 标签 / 答案搜索" value="{{keyword}}" bindinput="onKeywordInput" bindconfirm="loadData" />
        <button class="primary-btn search-btn" bindtap="loadData" loading="{{loading}}">刷新</button>
      </view>
      <scroll-view scroll-x class="filter-scroll" show-scrollbar="false">
        <view class="filter-row">
          <view class="filter-chip {{currentFilter === item.value ? 'filter-chip-active' : ''}}" wx:for="{{filters}}" wx:key="value" data-value="{{item.value}}" bindtap="onTapFilter">{{item.label}}</view>
        </view>
      </scroll-view>
      <view class="toolbar-note small-gap">支持在管理视角下查看已归档题目，并保留恢复入口；快捷审核 / 发布按钮会按角色权限动态展示。</view>
    </view>

    <view wx:if="{{list.length}}">
      <view class="card" wx:for="{{list}}" wx:key="_id">
        <view class="list-title-row">
          <view class="title title-small">{{item.title}}</view>
          <text class="meta-pill meta-pill-light">{{item.statusText}}</text>
        </view>
        <view class="meta-row wrap-row large-gap">
          <text class="meta-pill">{{item.subject || '未分类'}}</text>
          <text class="meta-pill meta-pill-light">{{item.category || '通用'}}</text>
          <text class="meta-pill meta-pill-light">{{item.difficultyText}}</text>
          <text class="meta-pill meta-pill-light">{{item.reviewStatusText}}</text>
          <text class="meta-pill meta-pill-light">{{item.lifecycleText}}</text>
          <text class="meta-pill meta-pill-light">{{item.versionText}}</text>
        </view>
        <view class="subtitle small-gap">答案：{{item.answer || '未填写'}}</view>
        <view class="subtitle small-gap">归属：{{item.ownerTeamText}} / {{item.ownerText}}</view>
        <view class="subtitle small-gap">导入：{{item.importBatchText}} ｜ {{item.importPositionText}}</view>
        <view class="subtitle">最近更新：{{item.updatedAtText}}</view>
        <view class="tag-row inline-tags small-gap">
          <text class="tag" wx:for="{{item.tags}}" wx:key="*this">{{item}}</text>
        </view>
        <view class="btn-row">
          <button wx:if="{{item.canEdit}}" size="mini" data-id="{{item._id}}" bindtap="goEdit">编辑</button>
          <button wx:if="{{item.canSendToReview}}" size="mini" data-id="{{item._id}}" bindtap="handleSendToReview">提审</button>
          <button wx:if="{{item.canApprove}}" size="mini" class="secondary-btn" data-id="{{item._id}}" bindtap="handleApprove">通过</button>
          <button wx:if="{{item.canReject}}" size="mini" class="danger-btn" data-id="{{item._id}}" bindtap="handleReject">驳回</button>
          <button wx:if="{{item.canPublish}}" size="mini" class="primary-btn" data-id="{{item._id}}" bindtap="handlePublish">发布</button>
          <button wx:if="{{item.canArchive}}" size="mini" class="danger-btn" data-id="{{item._id}}" bindtap="handleDelete">归档</button>
          <button wx:if="{{item.canRestore}}" size="mini" class="secondary-btn" data-id="{{item._id}}" bindtap="handleRestore">恢复</button>
        </view>
      </view>
    </view>

    <view wx:else class="card empty">暂无题目，试试切换筛选条件或搜索词。</view>
  </block>
</view>
