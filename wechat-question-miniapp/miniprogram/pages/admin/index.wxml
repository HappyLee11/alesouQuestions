<view class="container page-shell">
  <view class="hero-card">
    <view class="eyebrow">Admin Console</view>
    <view class="hero-title">题库治理后台</view>
    <view class="hero-subtitle">统一展示管理员校验、内容生命周期、审核态、导入治理、角色权限和审计轨迹，作为题库运营后台的总览入口。</view>
    <view class="quick-nav">
      <view class="quick-nav-item">权限校验</view>
      <view class="quick-nav-item">状态治理</view>
      <view class="quick-nav-item">批量导入</view>
      <view class="quick-nav-item">审计日志</view>
    </view>
  </view>

  <view class="glass-card">
    <view class="title">后台管理</view>
    <view wx:if="{{checking}}" class="subtitle">正在校验管理员权限...</view>
    <block wx:elif="{{isAdmin}}">
      <view class="subtitle">管理员校验已通过，可直接进行题库维护。后台首页集中呈现角色能力、导入任务和审计日志，方便日常运营处理。</view>
      <view class="meta-row wrap-row large-gap">
        <text class="meta-pill">OPENID：{{openid || '--'}}</text>
        <text class="meta-pill meta-pill-light">角色：{{admin && (admin.roleLabel || admin.role) ? (admin.roleLabel || admin.role) : 'admin'}}</text>
        <text class="meta-pill meta-pill-light">状态：已授权</text>
        <text class="meta-pill meta-pill-light" wx:if="{{admin && admin.ownerTeam}}">团队：{{admin.ownerTeam}}</text>
      </view>
      <view class="btn-row">
        <button class="primary-btn" bindtap="goList">题目列表</button>
        <button bindtap="goCreate">新增题目</button>
        <button bindtap="goImport">批量导入</button>
        <button class="secondary-btn" bindtap="goTaskCenter">任务中心</button>
      </view>
    </block>
    <block wx:else>
      <view class="subtitle">当前账号还不是管理员，但已经拿到了初始化所需的 OPENID。把下面的 JSON 粘到 `admins` 集合里，再回到后台刷新即可。</view>
      <view class="meta-row wrap-row large-gap">
        <text class="meta-pill">OPENID：{{openid || '--'}}</text>
        <text class="meta-pill meta-pill-light">状态：未授权</text>
      </view>
      <view class="feature-item">
        <view class="feature-title">1. 复制当前 OPENID</view>
        <view class="feature-desc">第一次配置管理员时，用这个值写入 `admins.openid`。</view>
      </view>
      <view class="feature-item">
        <view class="feature-title">2. 新建管理员记录</view>
        <view class="feature-desc">推荐角色：super_admin；记得把 enabled 设为 true。</view>
      </view>
      <view class="feature-item">
        <view class="feature-title">3. 创建缺失集合并导入首批数据</view>
        <view class="feature-desc">集合建议至少包括 questions / admins / import_tasks / audit_logs，然后去导入页完成首批题库预检。</view>
      </view>
      <view class="btn-row">
        <button class="primary-btn" bindtap="copyOpenid">复制 OPENID</button>
        <button bindtap="copyAdminSeed">复制管理员 JSON</button>
        <button bindtap="copyCollectionChecklist">复制集合清单</button>
        <button class="secondary-btn" bindtap="goImport">去导入页准备首批题目</button>
      </view>
    </block>
  </view>

  <view class="stats-grid admin-stats" wx:if="{{isAdmin}}">
    <view class="metric-card"><view class="metric-value">{{stats.total}}</view><view class="metric-label">总题数</view></view>
    <view class="metric-card"><view class="metric-value">{{stats.published}}</view><view class="metric-label">已发布</view></view>
    <view class="metric-card"><view class="metric-value">{{stats.review}}</view><view class="metric-label">审核中</view></view>
    <view class="metric-card"><view class="metric-value">{{stats.draft}}</view><view class="metric-label">草稿</view></view>
    <view class="metric-card"><view class="metric-value">{{stats.approved}}</view><view class="metric-label">审核通过</view></view>
    <view class="metric-card"><view class="metric-value">{{stats.pending}}</view><view class="metric-label">待处理</view></view>
    <view class="metric-card"><view class="metric-value">{{stats.rejected}}</view><view class="metric-label">已驳回</view></view>
    <view class="metric-card"><view class="metric-value">{{stats.deleted}}</view><view class="metric-label">回收站</view></view>
  </view>

  <view class="glass-card" wx:if="{{isAdmin && permissionGroups.length}}">
    <view class="section-header">
      <view>
        <view class="section-title">角色权限矩阵</view>
        <view class="section-caption">把管理员能力拆成明确的权限集合，便于运营分工、交接和权限核验。</view>
      </view>
      <text class="toolbar-note">当前角色：{{admin && (admin.roleLabel || admin.role) ? (admin.roleLabel || admin.role) : 'admin'}}</text>
    </view>
    <view class="permission-group" wx:for="{{permissionGroups}}" wx:key="key">
      <view class="field-label">{{item.label}}</view>
      <view class="meta-row wrap-row">
        <text class="meta-pill meta-pill-light permission-pill" wx:for="{{item.items}}" wx:key="key">{{item.label}}</text>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{isAdmin}}">
    <view class="section-header">
      <view>
        <view class="section-title">后台模块</view>
        <view class="section-caption">每个入口都能单独讲，也能串成完整治理链路。</view>
      </view>
    </view>
    <view class="panel-grid large-gap">
      <view class="panel-card panel-accent" wx:for="{{moduleCards}}" wx:key="title" data-action="{{item.action}}" bindtap="onTapModule">
        <view class="panel-title">{{item.title}}</view>
        <view class="panel-desc">{{item.desc}}</view>
      </view>
    </view>
  </view>

  <view class="glass-card" wx:if="{{isAdmin && recentImportTasks.length}}">
    <view class="section-header">
      <view>
        <view class="section-title">最近导入任务</view>
        <view class="section-caption">优先读取云端 import_tasks；拿不到时回退到本地回执缓存。</view>
      </view>
      <text class="toolbar-note">{{taskSourceLabel}}</text>
    </view>
    <view class="feature-item" wx:for="{{recentImportTasks}}" wx:key="taskId">
      <view class="feature-title">{{item.statusLabel}} ｜ {{item.taskName || item.batchId}}</view>
      <view class="feature-desc">批次：{{item.batchId}} ｜ 状态：{{item.taskStatus || '--'}} ｜ {{item.sourceType}} / {{item.templateType}} ｜ {{item.timeText}}</view>
      <view class="feature-desc">总 {{item.total}} ｜ 有效 {{item.valid}} ｜ 无效 {{item.invalid}} ｜ 预警 {{item.warnings}} ｜ 新增 {{item.inserted}} ｜ 更新 {{item.updated}}</view>
      <view class="btn-row">
        <button size="mini" class="secondary-btn" bindtap="continueImportTask" data-receipt-id="{{item.localReceiptId}}">{{item.resumable ? '继续处理这批任务' : '打开导入页'}}</button>
      </view>
    </view>
  </view>

  <view class="glass-card" wx:if="{{isAdmin && recentAuditLogs.length}}">
    <view class="section-header">
      <view>
        <view class="section-title">最近审计日志</view>
        <view class="section-caption">记录导入预检、导入执行、题目编辑、归档与恢复，方便说明责任链和可追溯性。</view>
      </view>
      <text class="toolbar-note">云端 audit_logs</text>
    </view>
    <view class="feature-item" wx:for="{{recentAuditLogs}}" wx:key="_id">
      <view class="feature-title">{{item.action}} ｜ {{item.entityTitle || item.entityId || '--'}}</view>
      <view class="feature-desc">{{item.summary || '--'}}</view>
      <view class="feature-desc">对象：{{item.entityType}} ｜ 结果：{{item.result || '--'}} ｜ 原因：{{item.reason || '--'}}</view>
      <view class="feature-desc">操作人：{{item.operatorName || item.operatorOpenid || '--'}} ｜ 角色：{{item.operatorRole || '--'}} ｜ 时间：{{item.timeText}}</view>
    </view>
  </view>

  <view class="glass-card" wx:if="{{isAdmin}}">
    <view class="section-header">
      <view>
        <view class="section-title">推荐工作路径</view>
        <view class="section-caption">按用户消费、内容维护、批量导入的顺序处理日常运营任务。</view>
      </view>
    </view>
    <view class="feature-item">
      <view class="feature-title">1. 先检查首页与搜索页</view>
      <view class="feature-desc">确认热门词、搜索历史、高亮结果、分页浏览和筛选分组可正常使用。</view>
    </view>
    <view class="feature-item">
      <view class="feature-title">2. 进入题目列表 / 编辑页</view>
      <view class="feature-desc">处理状态、审核、版本化内容字段，以及归档、快捷审核与恢复操作。</view>
    </view>
    <view class="feature-item">
      <view class="feature-title">3. 最后进入导入页和后台首页</view>
      <view class="feature-desc">检查任务预检、导入回执、角色权限矩阵与审计日志是否闭环。</view>
    </view>
  </view>

  <view class="card" wx:if="{{isAdmin}}">
    <view class="section-header">
      <view>
        <view class="section-title">这版后台强调的治理能力</view>
        <view class="section-caption">比“单纯增删改查”更接近真实内容运营系统。</view>
      </view>
    </view>
    <view class="feature-desc" wx:for="{{governanceChecklist}}" wx:key="*this">
      <text class="status-dot"></text>{{item}}
    </view>
  </view>
</view>
