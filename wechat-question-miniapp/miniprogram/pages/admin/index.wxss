/* admin page */
.permission-group {
  margin-top: 24rpx;
  padding-top: 24rpx;
  border-top: 1rpx solid #edf2f7;
}

.permission-group:first-of-type {
  margin-top: 18rpx;
  padding-top: 0;
  border-top: 0;
}

.permission-pill {
  margin-bottom: 12rpx;
}

.admin-stats .metric-card {
  width: calc(50% - 9rpx);
}

.panel-grid.large-gap {
  gap: 18rpx;
}

.feature-item + .feature-item {
  margin-top: 22rpx;
  padding-top: 22rpx;
  border-top: 1rpx solid #edf2f7;
}

.btn-row button {
  flex: 1 1 100%;
}
