/* task center page */

.page-task-center {
  padding-bottom: 40rpx;
}

.task-center-hero {
  padding-bottom: 34rpx;
}

.quick-nav {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 24rpx;
  position: relative;
  z-index: 1;
}

.quick-nav-item {
  padding: 12rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.94);
  font-size: 22rpx;
}

.workbench-next-action {
  margin-top: 18rpx;
}

.task-center-actions {
  align-items: stretch;
}

.task-center-action-btn {
  flex: 1 1 220rpx;
  min-width: 0;
}

.task-center-actions-compact {
  flex-direction: column;
}

.task-center-actions-compact .task-center-action-btn {
  width: 100%;
}

.task-center-inline-btn {
  min-width: 180rpx;
}

.insight-grid {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 20rpx;
}

.insight-grid-wide {
  flex-direction: row;
  flex-wrap: wrap;
  align-items: stretch;
}

.insight-card {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  border: 1rpx solid #dbe7fb;
  box-sizing: border-box;
}

.insight-grid-wide .insight-card {
  width: calc(50% - 8rpx);
}

.insight-btn,
.acceptance-btn {
  margin-top: 18rpx;
}

.task-center-todo-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 22rpx;
}

.task-center-todo-list-wide {
  flex-direction: row;
  flex-wrap: wrap;
  align-items: stretch;
}

.todo-card {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  border: 1rpx solid #dbe7fb;
  box-sizing: border-box;
}

.task-center-todo-list-wide .todo-card {
  width: calc(50% - 8rpx);
}

.todo-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.todo-card-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.66;
  color: #475569;
}

.todo-card button {
  margin-top: 18rpx;
}

.focus-grid {
  margin-bottom: 24rpx;
}

.focus-grid-wide .focus-card {
  width: calc(50% - 9rpx);
}

.focus-card {
  min-height: 196rpx;
}

.acceptance-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 18rpx;
}

.acceptance-item {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  border: 1rpx solid #dbe7fb;
}

.acceptance-item-pass {
  background: linear-gradient(180deg, #f8fbff 0%, #eef7ff 100%);
}

.acceptance-item-pending {
  background: linear-gradient(180deg, #fffaf2 0%, #fff2dd 100%);
}

.acceptance-item-top {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
  flex-wrap: wrap;
}

.acceptance-item-title-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex: 1;
}

.acceptance-item-title {
  flex: 1;
}

.tone-primary {
  background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 100%);
}

.tone-warning {
  background: linear-gradient(180deg, #fff7ed 0%, #ffedd5 100%);
}

.tone-success {
  background: linear-gradient(180deg, #ecfdf5 0%, #d1fae5 100%);
}

.tone-danger {
  background: linear-gradient(180deg, #fef2f2 0%, #fee2e2 100%);
}

.tone-neutral {
  background: linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
}

.queue-card,
.import-task-card,
.audit-card {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f4f8ff 100%);
  border: 1rpx solid #dbe7fb;
}

.task-center-card-title {
  display: -webkit-box;
  overflow: hidden;
  text-overflow: ellipsis;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

.import-stat-row,
.import-risk-row {
  margin-top: 18rpx;
}

.import-summary-note {
  margin-top: 14rpx;
}

@media (min-width: 768px) {
  .focus-card {
    min-height: 180rpx;
  }
}
