/* detail page */
.wrap-row {
  flex-wrap: wrap;
}

.page-detail {
  padding-bottom: 40rpx;
}

.detail-hero {
  padding-bottom: 34rpx;
}

.detail-hero-meta {
  margin-top: 22rpx;
}

.detail-hero-actions {
  margin-top: 24rpx;
}

.detail-stats .metric-card {
  width: calc(50% - 9rpx);
  min-width: 0;
}

.detail-panels {
  margin-top: 2rpx;
}

.detail-answer-summary {
  color: #1e3a8a;
}

.detail-content-card,
.detail-answer-card,
.detail-analysis-card,
.detail-meta-card {
  margin-bottom: 22rpx;
}

.detail-section-block + .detail-section-block {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #edf2f7;
}

.detail-content-box,
.detail-analysis-box {
  padding: 22rpx 22rpx;
  border-radius: 20rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7fb;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.option-card {
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7fb;
}

.answer-box {
  margin-top: 8rpx;
}

.inline-link {
  display: inline-block;
}

.detail-info-grid {
  margin-top: 18rpx;
}

.compact-result {
  padding: 0;
  margin-bottom: 0;
  box-shadow: none;
  border: 0;
}

.compact-result + .compact-result {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf2f7;
}

.compact-result-meta {
  margin-top: 14rpx;
}
