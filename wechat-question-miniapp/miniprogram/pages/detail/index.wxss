/* detail page */
.wrap-row {
  flex-wrap: wrap;
}

.page-detail {
  padding-bottom: 40rpx;
}

.detail-hero {
  padding-bottom: 34rpx;
}

.detail-hero-meta {
  margin-top: 22rpx;
}

.detail-hero-actions {
  margin-top: 24rpx;
}

.detail-stats .metric-card {
  width: calc(50% - 9rpx);
  min-width: 0;
}

.detail-panels {
  margin-top: 2rpx;
}

.detail-answer-summary {
  color: #1e3a8a;
}

.detail-governance-card,
.detail-content-card,
.detail-answer-card,
.detail-analysis-card,
.detail-meta-card {
  margin-bottom: 22rpx;
}

.detail-section-block + .detail-section-block {
  margin-top: 28rpx;
  padding-top: 28rpx;
  border-top: 1rpx solid #edf2f7;
}

.detail-content-box,
.detail-analysis-box {
  padding: 22rpx 22rpx;
  border-radius: 20rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7fb;
}

.option-list {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
}

.option-card {
  padding: 20rpx 22rpx;
  border-radius: 18rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7fb;
}

.answer-box {
  margin-top: 8rpx;
}

.inline-link {
  display: inline-block;
}

.detail-info-grid {
  margin-top: 18rpx;
}

.detail-risk-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 22rpx;
}

.detail-risk-card {
  padding: 22rpx 20rpx;
  border-radius: 22rpx;
  border: 1rpx solid #dbe7fb;
}

.detail-risk-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #0f172a;
}

.detail-risk-desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.66;
  color: #475569;
}

.detail-governance-actions button {
  min-width: 190rpx;
}

.tone-danger {
  background: linear-gradient(180deg, #fef2f2 0%, #fee2e2 100%);
}

.tone-warning {
  background: linear-gradient(180deg, #fff7ed 0%, #ffedd5 100%);
}

.tone-neutral {
  background: linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
}

.compact-result {
  padding: 0;
  margin-bottom: 0;
  box-shadow: none;
  border: 0;
}

.compact-result + .compact-result {
  margin-top: 18rpx;
  padding-top: 18rpx;
  border-top: 1rpx solid #edf2f7;
}

.compact-result-meta {
  margin-top: 14rpx;
}
