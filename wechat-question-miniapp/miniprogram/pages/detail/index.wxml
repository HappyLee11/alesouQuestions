<view class="container">
  <view wx:if="{{detail}}" class="card">
    <view class="title no-gap">{{detail.title}}</view>
    <view class="meta-row large-gap wrap-row">
      <text class="meta-pill">{{detail.subject || '未分类'}}</text>
      <text class="meta-pill meta-pill-light">{{detail.category || '通用'}}</text>
      <text class="meta-pill meta-pill-light">{{detail.difficultyText}}</text>
      <text class="meta-pill meta-pill-light">{{detail.statusText}}</text>
    </view>

    <view class="field-block" wx:if="{{detail.titleVariants && detail.titleVariants.length}}">
      <view class="field-label">标题变体 / 别名</view>
      <view class="tag-row">
        <text class="tag" wx:for="{{detail.titleVariants}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <view class="field-block">
      <view class="field-label">题干</view>
      <view class="content-text">{{detail.content}}</view>
    </view>

    <view class="field-block" wx:if="{{detail.options && detail.options.length}}">
      <view class="field-label">选项</view>
      <view class="option-item" wx:for="{{detail.options}}" wx:key="index">{{index + 1}}. {{item}}</view>
    </view>

    <view class="field-block">
      <view class="field-label">答案</view>
      <view class="answer-box">{{showFullAnswer ? detail.answer : detail.answerShort}}</view>
      <text class="link-text small-gap inline-link" bindtap="toggleAnswer">{{showFullAnswer ? '收起完整答案' : '查看完整答案'}}</text>
    </view>

    <view class="field-block">
      <view class="field-label">解析</view>
      <view class="content-text">{{detail.analysis || '暂无解析'}}</view>
    </view>

    <view class="field-block">
      <view class="field-label">题目标签</view>
      <view class="tag-row">
        <text class="tag" wx:for="{{detail.tags}}" wx:key="*this">{{item}}</text>
      </view>
    </view>

    <view class="info-grid">
      <view class="info-item">
        <view class="info-label">来源</view>
        <view class="info-value">{{detail.source || '--'}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">年份</view>
        <view class="info-value">{{detail.year || '--'}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">分值</view>
        <view class="info-value">{{detail.score || '--'}}</view>
      </view>
      <view class="info-item">
        <view class="info-label">更新时间</view>
        <view class="info-value">{{detail.updatedAtText}}</view>
      </view>
    </view>
  </view>

  <view class="card" wx:if="{{related.length}}">
    <view class="section-title">相关题目</view>
    <view class="subtitle">当用户觉得当前答案还不够时，可继续跳转到相近题目，而不是直接终止在单题详情。</view>
    <view class="result-card compact-result" wx:for="{{related}}" wx:key="_id" data-id="{{item._id}}" bindtap="goRelated">
      <view class="result-title">{{item.title}}</view>
      <view class="meta-row wrap-row small-gap">
        <text class="meta-pill">{{item.subject || '未分类'}}</text>
        <text class="meta-pill meta-pill-light">{{item.difficultyText}}</text>
      </view>
    </view>
  </view>

  <view wx:elif="{{!loading}}" class="card empty">未找到题目，可能已被归档或 ID 不存在。</view>
</view>
