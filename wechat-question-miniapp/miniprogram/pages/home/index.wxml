<view class="container page-shell page-home">
  <view class="hero-card home-hero">
    <view class="eyebrow">阿乐搜题</view>
    <view class="hero-title">打开就能搜题</view>
    <view class="hero-subtitle">输入题目关键词、题干片段或知识点，马上开始查答案和解析。</view>

    <view class="home-search-box">
      <input class="input home-search-input" placeholder="例如：HTTP 状态码 404 是什么" value="{{keyword}}" bindinput="onKeywordInput" confirm-type="search" bindconfirm="submitSearch" />
      <button class="primary-btn home-search-btn" bindtap="submitSearch">搜索</button>
    </view>

    <view class="quick-hint-row">
      <text class="quick-hint">支持题干片段</text>
      <text class="quick-hint">支持知识点</text>
      <text class="quick-hint">支持标签词</text>
    </view>
  </view>

  <view class="glass-card section-block">
    <view class="section-header">
      <view>
        <view class="section-title">热门搜索</view>
        <view class="section-caption">点一下就能直接搜</view>
      </view>
    </view>
    <view class="tag-row small-gap">
      <text class="tag tag-clickable" wx:for="{{hotTerms}}" wx:key="*this" data-term="{{item}}" bindtap="onTapTerm">{{item}}</text>
    </view>
  </view>

  <view class="card section-block" wx:if="{{history.length}}">
    <view class="section-header">
      <view>
        <view class="section-title">最近搜索</view>
        <view class="section-caption">继续上次的查找</view>
      </view>
      <text class="link-text" bindtap="clearHistory">清空</text>
    </view>
    <view class="tag-row small-gap">
      <text class="tag tag-clickable" wx:for="{{history}}" wx:key="*this" data-term="{{item}}" bindtap="onTapTerm">{{item}}</text>
    </view>
  </view>

  <view class="card section-block" wx:if="{{subjects.length}}">
    <view class="section-header">
      <view>
        <view class="section-title">按学科找题</view>
        <view class="section-caption">先选范围，再看结果更快</view>
      </view>
    </view>
    <view class="tag-row small-gap">
      <text class="filter-chip tag-clickable" wx:for="{{subjects}}" wx:key="*this" data-term="{{item}}" bindtap="onTapTerm">{{item}}</text>
    </view>
  </view>

  <view class="glass-card section-block" wx:if="{{sampleQuestions.length}}">
    <view class="section-header">
      <view>
        <view class="section-title">高频题推荐</view>
        <view class="section-caption">打开常搜题目，直接查看答案与解析</view>
      </view>
    </view>
    <view class="sample-list">
      <view class="sample-item" wx:for="{{sampleQuestions}}" wx:key="_id" data-id="{{item._id}}" bindtap="goDetail">
        <view class="sample-title">{{item.title}}</view>
        <view class="meta-row wrap-row small-gap">
          <text class="meta-pill">{{item.subject || '未分类'}}</text>
          <text class="meta-pill meta-pill-light">{{item.difficultyText}}</text>
        </view>
      </view>
    </view>
  </view>
</view>
