/* page styles inherit app.wxss */

.page-home {
  padding-bottom: 40rpx;
}

.home-search-card {
  padding: 28rpx 24rpx;
}

.home-title-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.home-title {
  font-size: 40rpx;
  font-weight: 700;
  color: #0f172a;
  line-height: 1.2;
}

.home-admin-btn {
  min-width: 120rpx;
}

.home-search-box {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 24rpx;
}

.home-search-input {
  width: 100%;
  background: rgba(255, 255, 255, 0.98);
  color: #111827;
}

.home-search-btn {
  width: 100%;
  min-width: 0;
  height: 86rpx;
  font-size: 30rpx;
}

.compact-section-header {
  align-items: center;
}

.sample-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 10rpx;
}

.sample-item {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f4f8ff 100%);
  border: 1rpx solid #dbe7fb;
}

.sample-title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.58;
  color: #0f172a;
}

.admin-entry-card {
  margin-top: 6rpx;
}

.admin-meta-row {
  margin-top: 10rpx;
}

.admin-entry-summary {
  margin-top: 16rpx;
}

.admin-entry-actions button {
  min-width: 190rpx;
}
