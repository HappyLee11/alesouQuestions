/* page styles inherit app.wxss */

.home-hero {
  padding-bottom: 32rpx;
}

.home-search-box {
  display: flex;
  gap: 16rpx;
  margin-top: 28rpx;
  align-items: center;
  position: relative;
  z-index: 1;
}

.home-search-input {
  flex: 1;
  background: rgba(255, 255, 255, 0.96);
  color: #111827;
}

.home-search-btn {
  min-width: 168rpx;
}

.quick-hint-row {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 20rpx;
  position: relative;
  z-index: 1;
}

.quick-hint {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
}

.sample-list {
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.sample-item {
  padding: 22rpx;
  border-radius: 22rpx;
  background: #f8fbff;
  border: 1rpx solid #dbe7fb;
}

.sample-title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.6;
  color: #0f172a;
}
