/* page styles inherit app.wxss */

.page-home {
  padding-bottom: 40rpx;
}

.home-hero {
  padding-bottom: 36rpx;
}

.home-search-box {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 30rpx;
  position: relative;
  z-index: 1;
}

.home-search-input {
  width: 100%;
  background: rgba(255, 255, 255, 0.96);
  color: #111827;
}

.home-search-btn {
  width: 100%;
  min-width: 0;
  height: 86rpx;
  font-size: 30rpx;
}

.quick-hint-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
  position: relative;
  z-index: 1;
}

.quick-hint {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
}

.sample-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 10rpx;
}

.sample-item {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f4f8ff 100%);
  border: 1rpx solid #dbe7fb;
}

.sample-title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.58;
  color: #0f172a;
}
