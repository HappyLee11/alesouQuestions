/* page styles inherit app.wxss */

.page-home {
  padding-bottom: 40rpx;
}

.home-hero {
  padding-bottom: 36rpx;
}

.home-search-box {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 30rpx;
  position: relative;
  z-index: 1;
}

.home-search-input {
  width: 100%;
  background: rgba(255, 255, 255, 0.96);
  color: #111827;
}

.home-search-btn {
  width: 100%;
  min-width: 0;
  height: 86rpx;
  font-size: 30rpx;
}

.quick-hint-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 22rpx;
  position: relative;
  z-index: 1;
}

.quick-hint {
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(255, 255, 255, 0.16);
  color: rgba(255, 255, 255, 0.92);
  font-size: 22rpx;
}

.admin-shortcut-card {
  overflow: hidden;
}

.admin-shortcut-header {
  align-items: flex-start;
}

.admin-summary-text {
  margin-top: 18rpx;
}

.admin-task-highlight {
  margin-top: 22rpx;
  margin-bottom: 0;
}

.admin-task-badges {
  margin-top: 16rpx;
}

.todo-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 22rpx;
}

.todo-card {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  border: 1rpx solid #dbe7fb;
}

.todo-card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: #0f172a;
}

.todo-card-desc {
  margin-top: 10rpx;
  font-size: 25rpx;
  line-height: 1.66;
  color: #475569;
}

.todo-card button {
  margin-top: 18rpx;
}

.tone-primary {
  background: linear-gradient(180deg, #eff6ff 0%, #dbeafe 100%);
}

.tone-warning {
  background: linear-gradient(180deg, #fff7ed 0%, #ffedd5 100%);
}

.tone-success {
  background: linear-gradient(180deg, #ecfdf5 0%, #d1fae5 100%);
}

.tone-danger {
  background: linear-gradient(180deg, #fef2f2 0%, #fee2e2 100%);
}

.tone-neutral {
  background: linear-gradient(180deg, #f8fbff 0%, #eef4ff 100%);
}

.admin-action-row button {
  min-width: 200rpx;
}

.sample-list {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-top: 10rpx;
}

.sample-item {
  padding: 24rpx 22rpx;
  border-radius: 24rpx;
  background: linear-gradient(180deg, #fbfdff 0%, #f4f8ff 100%);
  border: 1rpx solid #dbe7fb;
}

.sample-title {
  font-size: 30rpx;
  font-weight: 600;
  line-height: 1.58;
  color: #0f172a;
}
